{
  "name": "flugrekorder",
  "version": "1.1.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rspieker/flugrekorder.git"
  },
  "bugs": {
    "url": "https://github.com/rspieker/flugrekorder/issues"
  },
  "homepage": "https://github.com/rspieker/flugrekorder#readme",
  "main": "dist/flugrekorder.js",
  "module": "dist/flugrekorder.mjs",
  "types": "dist/flugrekorder.d.ts",
  "exports": {
    ".": {
      "types": "./dist/flugrekorder.d.ts",
      "import": "./dist/flugrekorder.mjs",
      "require": "./dist/flugrekorder.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome lint source",
    "format": "biome format source",
    "check": "biome check source",
    "check:write": "biome check --write source",
    "release": "release-it --ci",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit && npm run test:functional",
    "test:unit": "node --require ./test.register.cjs --test 'source/**/*.spec.ts'",
    "test:functional": "node --require ./test.register.cjs --test 'test/**/*.spec.ts'",
    "test:coverage": "odz -- node --require ./test.register.cjs --test 'source/**/*.spec.ts' 'test/**/*.spec.ts'",
    "prepare": "husky || true"
  },
  "keywords": [
    "proxy",
    "recorder",
    "reflect",
    "trap",
    "observer",
    "flight recorder",
    "logger"
  ],
  "author": "Rogier Spieker <rogier+npm@konfirm.eu>",
  "license": "MIT",
  "description": "A tireless, impartial, punctilious, incurious spectator. It witnesses every interaction. It takes note. It understands nothing. Remarkably, this is a feature.",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/config-conventional": "^20.5.3",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.8.0",
    "commitlint": "^20.5.3",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "one-double-zero": "^1.1.1",
    "release-it": "^20.0.1",
    "template-literal-each": "^3.0.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
